# x0 = dividend
# x1 = divisor
# result → x2

x3 = x1

# scale: while x3*2 <= x0
while x3 < x0:
    x4 = x3 << 1
    if x4 > x0:
        x3 = x3  # break simulation
    else:
        x3 = x4

# division
while x3 > x1:
    if x0 > x3:
        x0 = x0 - x3
    x3 = x3 >> 1

# final step
if x0 > x3:
    x0 = x0 - x3

x2 = x0
