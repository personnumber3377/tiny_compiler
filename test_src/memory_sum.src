x0 = 0      # base address
x1 = 4      # length

# initialize memory
x2 = 1
mem[x0] = x2

x2 = 2
x3 = x0 + 1
mem[x3] = x2

x2 = 3
x3 = x0 + 2
mem[x3] = x2

x2 = 4
x3 = x0 + 3
mem[x3] = x2

# sum
x2 = 0      # sum
x3 = 0      # index

while x3 < x1:
    x4 = x0 + x3
    x5 = mem[x4]
    x2 = x2 + x5
    x3 = x3 + 1
